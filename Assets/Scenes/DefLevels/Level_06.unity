--- !u!1001 &1043532828
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 0}
    m_Modifications:
    - target: {fileID: 846471609284694202, guid: 4c5f1da3e5bb7b0469e905f6fe813a98, type: 3}
      propertyPath: m_text
      value: "Witness-thread frays into sanctioned punctuation\u2014periods that
        end \t        too early, commas that refuse to connect, ellipses that stretch
        like caution tape. The calendar forgets its own dates on purpose, rehearsing
        a clean amnesia that feels almost ergonomic. Grief is categorized as \u201Cmiscellaneous,\u201D
        mourning is translated into \u201Cmisunderstanding,\u201D and loss is rebranded
        as \u201Cnoise reduction.\u201D Scarred communities become quiet neighborhoods
        on a map with softened borders; broken families become a statistic with rounded
        edges. Every question is answered with a mirror, every mirror is covered
        with a disclaimer, and every disclaimer is signed by a pen that writes in
        disappearing ink."
      objectReference: {fileID: 0}
    - target: {fileID: 846471609284694202, guid: 4c5f1da3e5bb7b0469e905f6fe813a98, type: 3}
      propertyPath: m_fontSize
